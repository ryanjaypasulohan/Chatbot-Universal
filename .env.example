# Wild Script — copy to .env for local dev (never commit .env)

# Supabase (https://supabase.com — free tier)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Groq LLM (https://console.groq.com — free tier)
GROQ_API_KEY=your_groq_api_key

# Optional
# OPENROUTER_API_KEY=
# DATABASE_URL=          # not required; app uses Supabase client
# NODE_ENV=production
# PORT=3000
# PUBLIC_APP_URL=https://your-app.onrender.com
# ALLOWED_ORIGIN=https://your-app.onrender.com
