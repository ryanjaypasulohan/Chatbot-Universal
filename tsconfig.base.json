{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@ai-chatbot/shared": ["packages/shared/src/index.ts"],
      "@ai-chatbot/*": ["packages/*/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}