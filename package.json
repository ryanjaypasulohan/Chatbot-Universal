{
  "name": "ai-universal-chatbot",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter \"@ai-chatbot/api\" run dev",
    "build": "pnpm --filter @ai-chatbot/shared run build && pnpm --filter @ai-chatbot/embeddings run build && pnpm --filter @ai-chatbot/api run build",
    "build:api": "pnpm run build",
    "start": "pnpm --filter @ai-chatbot/api run start",
    "start:api": "pnpm run start"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.22.3"
  }
}